---
interface Props { value: number; rationale: string }
const { value, rationale } = Astro.props;
const pct = Math.round(value * 100);
const color = value >= 0.8 ? "text-ok" : value >= 0.5 ? "text-warn" : "text-err";
const stroke = value >= 0.8 ? "#4ade80" : value >= 0.5 ? "#fbbf24" : "#f87171";
const circumference = 2 * Math.PI * 42;
const dash = (value * circumference).toFixed(2);
---
<div class="panel p-4 flex items-center gap-4" aria-label={`Confidence ${pct}%`}>
  <svg width="96" height="96" viewBox="0 0 96 96" role="img" aria-label={`${pct} percent confidence`}>
    <circle cx="48" cy="48" r="42" fill="none" stroke="#262a31" stroke-width="8" />
    <circle
      cx="48" cy="48" r="42" fill="none" stroke={stroke} stroke-width="8"
      stroke-linecap="round" stroke-dasharray={`${dash} ${circumference}`}
      transform="rotate(-90 48 48)"
    />
    <text x="48" y="54" text-anchor="middle" class="mono" fill="#e7e9ee" font-size="18" font-weight="600">{pct}%</text>
  </svg>
  <div class="flex-1">
    <div class={`text-sm font-medium ${color}`}>confidence</div>
    <p class="text-xs text-fg/80 mt-1">{rationale}</p>
  </div>
</div>
