---
import type { Step } from "../lib/schemas";
interface Props { step: Step }
const { step } = Astro.props;

const toolColor: Record<string, string> = {
  schema: "text-tool-schema",
  top_errors: "text-tool-top_errors",
  search: "text-tool-search",
  around: "text-tool-around",
  trace: "text-tool-trace",
  submit_incident_report: "text-tool-submit",
  llm_query: "text-muted",
};
const cls = toolColor[step.tool] ?? "text-fg";
const argsPreview = Object.entries(step.args ?? {})
  .map(([k, v]) => `${k}=${typeof v === "string" ? v : JSON.stringify(v)}`)
  .join(" ");
---
<article class="border border-border rounded-md bg-surface2 p-3">
  <header class="flex items-baseline gap-3 mb-2 font-mono text-xs">
    <span class="text-muted">{String(step.step).padStart(2, "0")}</span>
    <span class={`font-medium ${cls}`}>{step.tool}</span>
    <span class="text-muted truncate">{argsPreview}</span>
    <span class="ml-auto text-muted">{step.elapsed_ms}ms</span>
  </header>
  {step.stdout_excerpt && (
    <pre class="mono text-xs text-fg/90 bg-bg border border-border rounded p-2 overflow-x-auto whitespace-pre-wrap">{step.stdout_excerpt}</pre>
  )}
</article>
