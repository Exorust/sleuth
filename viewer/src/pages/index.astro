---
import Base from "../layouts/Base.astro";
import Trajectory from "../components/Trajectory.astro";
import EvidencePanel from "../components/EvidencePanel.astro";
import ConfidenceDial from "../components/ConfidenceDial.astro";
import GroundTruthDiff from "../components/GroundTruthDiff.astro";
import { CaseFile, GroundTruth } from "../lib/schemas";

import demoRaw from "../../../examples/checkout-incident/incident.sleuth.json";
import gtRaw from "../../../examples/checkout-incident/ground_truth.json";

const demo = CaseFile.parse(demoRaw);
const gt = GroundTruth.parse(gtRaw);

const sealed = demo.termination_reason === "submitted";
const statusColor = sealed ? "text-ok" : "text-warn";
const statusDotColor = sealed ? "bg-ok" : "bg-warn";
const caseId = "SLEUTH-0001";
const sig = demo.logs_manifest.files[0]?.sha256?.slice(0, 12) ?? "unsigned";
---
<Base title="Sleuth — case file SLEUTH-0001" description="Use an RLM to figure out your log files.">
  <!-- Terminal bar -->
  <div class="border-b border-border bg-surface/60 backdrop-blur supports-[backdrop-filter]:bg-surface/40 sticky top-0 z-10">
    <div class="max-w-6xl mx-auto px-4 md:px-6 h-10 flex items-center gap-3 font-mono text-xs">
      <div class="flex gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-err/70"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-warn/70"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-ok/70"></span>
      </div>
      <span class="text-muted hidden sm:inline">~/incidents/checkout-2026-04-17</span>
      <span class="text-muted truncate">
        <span class="text-accent">$</span> sleuth ask <span class="text-fg/90">"{demo.question.slice(0, 48)}{demo.question.length > 48 ? "…" : ""}"</span>
      </span>
      <span class="ml-auto flex items-center gap-2">
        <span class={`relative flex w-2 h-2`}>
          <span class={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-60 ${statusDotColor}`}></span>
          <span class={`relative inline-flex rounded-full h-2 w-2 ${statusDotColor}`}></span>
        </span>
        <span class={statusColor}>{demo.termination_reason}</span>
      </span>
    </div>
  </div>

  <main class="max-w-6xl mx-auto px-4 md:px-6 py-10 md:py-14">

    <!-- HERO: case file stamp -->
    <section class="relative mb-10 md:mb-14">
      <!-- faint grid texture -->
      <div class="absolute inset-0 -z-10 opacity-[0.07] pointer-events-none"
           style="background-image: linear-gradient(to right, #e7e9ee 1px, transparent 1px), linear-gradient(to bottom, #e7e9ee 1px, transparent 1px); background-size: 32px 32px; mask-image: radial-gradient(ellipse at top left, black 0%, transparent 70%);"></div>

      <div class="flex items-start justify-between gap-6 flex-wrap mb-6">
        <div class="font-mono text-xs text-muted leading-5">
          <div><span class="text-accent">CASE</span> <span class="text-fg">#{caseId}</span></div>
          <div>SIG <span class="text-fg/80">{sig}</span></div>
          <div>v{demo.version} · {demo.model.provider}/{demo.model.name}</div>
        </div>
        <a href="https://github.com/Exorust/sleuth"
           class="font-mono text-xs px-3 py-1.5 border border-border hover:border-accent hover:text-accent transition-colors rounded">
          <span class="text-muted mr-1">$</span>pip install sleuth-rlm
        </a>
      </div>

      <div class="border-l-2 border-accent pl-4 md:pl-6">
        <div class="font-mono text-[10px] tracking-[0.2em] text-accent mb-3">THE QUESTION</div>
        <h1 class="font-mono text-2xl md:text-4xl lg:text-5xl font-medium leading-tight text-fg text-balance">
          {demo.question}
        </h1>
      </div>

      <!-- stat bar -->
      <div class="mt-8 grid grid-cols-2 md:grid-cols-5 gap-px bg-border border border-border rounded overflow-hidden">
        <div class="bg-bg p-4">
          <div class="font-mono text-[10px] tracking-widest text-muted mb-1">ROWS</div>
          <div class="font-mono text-xl tabular-nums">{demo.logs_manifest.total_rows.toLocaleString()}</div>
        </div>
        <div class="bg-bg p-4">
          <div class="font-mono text-[10px] tracking-widest text-muted mb-1">FILES</div>
          <div class="font-mono text-xl tabular-nums">{demo.logs_manifest.files.length}</div>
        </div>
        <div class="bg-bg p-4">
          <div class="font-mono text-[10px] tracking-widest text-muted mb-1">STEPS</div>
          <div class="font-mono text-xl tabular-nums">{demo.trajectory.length}</div>
        </div>
        <div class="bg-bg p-4">
          <div class="font-mono text-[10px] tracking-widest text-muted mb-1">LLM CALLS</div>
          <div class="font-mono text-xl tabular-nums">{demo.usage.llm_calls}</div>
        </div>
        <div class="bg-bg p-4 col-span-2 md:col-span-1">
          <div class="font-mono text-[10px] tracking-widest text-muted mb-1">WALL CLOCK</div>
          <div class="font-mono text-xl tabular-nums">{demo.usage.wall_clock_s}s</div>
        </div>
      </div>
    </section>

    <!-- What this is (collapsible, less screen real estate) -->
    <details class="mb-10 panel p-4 group">
      <summary class="cursor-pointer list-none flex items-center gap-3 font-mono text-xs text-muted hover:text-fg">
        <span class="text-accent group-open:rotate-90 transition-transform inline-block">▸</span>
        <span class="tracking-wider">README — what am i looking at?</span>
      </summary>
      <div class="mt-4 pt-4 border-t border-border space-y-3 text-sm text-fg/80 leading-relaxed">
        <p>
          One run of the <a href="https://github.com/Exorust/sleuth" class="text-accent hover:underline">Sleuth</a> agent on a synthetic 72-row, 5-service incident: a Stripe API key rotation that cascaded into checkout 5xx errors. You asked a question in English. The agent wrote Python over your logs. This page renders the signed JSON it produced.
        </p>
        <p class="text-fg/60">
          Every run produces one <strong class="text-fg">case file</strong>: question, trajectory, root cause, cited evidence. Self-contained. Replayable. Shareable.
        </p>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1.5 text-fg/70 font-mono text-xs pt-2">
          <li><span class="text-accent">▸</span> <strong class="text-fg">Root cause</strong> — the agent's answer</li>
          <li><span class="text-accent">▸</span> <strong class="text-fg">Confidence</strong> — how sure, in its own words</li>
          <li><span class="text-accent">▸</span> <strong class="text-fg">Ground truth</strong> — pass/fail gate vs known answer</li>
          <li><span class="text-accent">▸</span> <strong class="text-fg">Evidence</strong> — cited log lines with ±3 context</li>
          <li><span class="text-accent">▸</span> <strong class="text-fg">Trajectory</strong> — every tool call, in order</li>
        </ul>
      </div>
    </details>

    {demo.report && (
      <>
        <!-- ROOT CAUSE: the headline answer -->
        <section class="mb-6 relative">
          <div class="font-mono text-[10px] tracking-[0.2em] text-accent mb-3">THE ANSWER</div>
          <div class="panel p-6 md:p-8 border-accent/30 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-accent"></div>
            <p class="font-sans text-fg text-lg md:text-xl leading-snug mb-6">
              {demo.report.root_cause}
            </p>
            <div class="pt-5 border-t border-border">
              <div class="font-mono text-[10px] tracking-[0.2em] text-muted mb-2">REMEDIATION</div>
              <p class="font-sans text-fg/85 text-sm md:text-base leading-relaxed">
                {demo.report.remediation}
              </p>
            </div>
          </div>
        </section>

        <!-- Confidence + GT side by side -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <ConfidenceDial value={demo.report.confidence} rationale={demo.report.confidence_rationale} />
          <GroundTruthDiff report={demo.report} groundTruth={gt} />
        </div>
      </>
    )}

    <div class="space-y-4">
      {demo.report && <EvidencePanel evidence={demo.report.evidence} />}
      <Trajectory trajectory={demo.trajectory} />
    </div>

    <footer class="mt-16 pt-6 border-t border-border font-mono text-xs text-muted flex flex-wrap items-center gap-4">
      <span class="text-accent">$</span>
      <span>end of case file</span>
      <span class="text-fg/40">·</span>
      <span>{sig}</span>
      <a href="https://github.com/Exorust/sleuth" class="ml-auto hover:text-accent">github</a>
      <a href="https://exorust.github.io/sleuth/" class="hover:text-accent">docs</a>
      <span>Apache-2.0</span>
    </footer>
  </main>
</Base>
