---
import Base from "../layouts/Base.astro";
import Trajectory from "../components/Trajectory.astro";
import EvidencePanel from "../components/EvidencePanel.astro";
import ConfidenceDial from "../components/ConfidenceDial.astro";
import GroundTruthDiff from "../components/GroundTruthDiff.astro";
import { CaseFile, GroundTruth } from "../lib/schemas";

import demoRaw from "../../../examples/checkout-incident/incident.rlm.json";
import gtRaw from "../../../examples/checkout-incident/ground_truth.json";

const demo = CaseFile.parse(demoRaw);
const gt = GroundTruth.parse(gtRaw);
---
<Base title="rlm-logger — case file viewer" description="Git bisect for production incidents.">
  <main class="max-w-5xl mx-auto px-4 md:px-6 py-8 md:py-12">
    <section class="panel p-5 mb-6 border-accent/40">
      <div class="flex items-baseline gap-3 mb-3 flex-wrap">
        <h1 class="font-mono text-xl md:text-2xl font-semibold">rlm-logger</h1>
        <span class="mono-tag text-accent border-accent/50">demo case file</span>
      </div>
      <p class="font-sans text-fg text-base leading-relaxed mb-3">
        <strong>What this is:</strong> one run of the <a href="https://github.com/Exorust/rlm-logger" class="text-accent hover:underline">rlm-logger</a> agent against a synthetic 72-row, 5-service log fixture of a <em>Stripe API key rotation that cascaded into checkout 5xx errors</em>. You asked a question in English, the agent wrote Python over your logs, and this page is the signed output it produced.
      </p>
      <p class="font-sans text-fg/80 text-sm leading-relaxed mb-3">
        Every run produces one JSON document called a <strong>case file</strong>. It holds the question, every step the agent took, the root cause it landed on, and the log lines it cited. This viewer just renders that JSON.
      </p>
      <details class="font-sans text-sm text-fg/80 leading-relaxed">
        <summary class="cursor-pointer text-muted hover:text-accent">What am I looking at, panel by panel?</summary>
        <ul class="mt-2 space-y-1 list-disc list-inside">
          <li><strong>Question</strong> — what a human asked in English.</li>
          <li><strong>Root cause + remediation</strong> — the agent's final answer and what to do about it.</li>
          <li><strong>Confidence</strong> — how sure the agent is, in its own words.</li>
          <li><strong>Ground truth</strong> — pass/fail gates. This fixture has a known answer, so we can grade whether the agent cited the right events and avoided the red herrings.</li>
          <li><strong>Evidence</strong> — actual log lines the agent pointed at, with ±3 lines of context.</li>
          <li><strong>Trajectory</strong> — the full reasoning loop: every tool call, every observation, in order. This is the "show your work" section.</li>
        </ul>
      </details>
    </section>

    <header class="mb-8">
      <div class="flex items-baseline gap-3 mb-3 flex-wrap">
        <span class="text-xs text-muted tracking-wide font-mono">the question</span>
        <span class="mono-tag">v{demo.version}</span>
        <span class="mono-tag text-accent border-accent/50">{demo.termination_reason}</span>
      </div>
      <p class="font-sans text-fg/90 text-base md:text-lg max-w-3xl">{demo.question}</p>
      <div class="mt-3 flex flex-wrap gap-2 font-mono text-xs text-muted">
        <span>{demo.model.provider}/{demo.model.name}</span>
        <span>·</span>
        <span>{demo.logs_manifest.total_rows} rows</span>
        <span>·</span>
        <span>{demo.logs_manifest.files.length} files</span>
        <span>·</span>
        <span>{demo.usage.wall_clock_s}s</span>
        <span>·</span>
        <span>{demo.usage.llm_calls} llm calls</span>
      </div>
    </header>

    {demo.report && (
      <section class="panel p-5 mb-6" aria-label="Root cause">
        <h2 class="text-xs text-muted tracking-wide mb-2">root cause</h2>
        <p class="font-sans text-fg text-base leading-relaxed">{demo.report.root_cause}</p>
        <h3 class="text-xs text-muted tracking-wide mt-4 mb-2">remediation</h3>
        <p class="font-sans text-fg/90 text-sm leading-relaxed">{demo.report.remediation}</p>
      </section>
    )}

    {demo.report && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <ConfidenceDial value={demo.report.confidence} rationale={demo.report.confidence_rationale} />
        <GroundTruthDiff report={demo.report} groundTruth={gt} />
      </div>
    )}

    <div class="space-y-4">
      {demo.report && <EvidencePanel evidence={demo.report.evidence} />}
      <Trajectory trajectory={demo.trajectory} />
    </div>

    <footer class="mt-12 pt-6 border-t border-border text-xs text-muted font-mono flex flex-wrap gap-4">
      <a href="https://github.com/Exorust/rlm-logger" class="hover:text-accent">github</a>
      <a href="https://exorust.github.io/rlm-logger/" class="hover:text-accent">docs</a>
      <span class="ml-auto">Apache-2.0</span>
    </footer>
  </main>
</Base>
